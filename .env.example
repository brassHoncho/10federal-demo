# Required: your Anthropic API key for the Co-Pilot streaming endpoint.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional: override the model id. Defaults to claude-sonnet-4-5-20250929.
# When 4.6 stabilizes, update to claude-sonnet-4-6-<date>.
# ANTHROPIC_MODEL=claude-sonnet-4-6-20250514
